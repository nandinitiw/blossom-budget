# PostgreSQL connection string (Neon / Supabase / Vercel Postgres in production)
DATABASE_URL="postgresql://blossom:blossom_dev@localhost:5433/blossom_budget"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Optional Google OAuth (leave blank to disable the Google button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 32-byte hex key for AES-256-GCM encryption of Plaid access tokens.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Plaid — from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox" # sandbox | production

# Optional. Enables OAuth banks (Chase, BofA, Wells Fargo, etc.) — without it,
# only non-OAuth institutions connect. Must exactly match a URI you've added
# under Plaid Dashboard > Team Settings > API > Allowed redirect URIs, e.g.
# "https://your-app.vercel.app/accounts". Leave blank until that's registered
# — Plaid rejects Link token creation entirely if this is set but unregistered.
PLAID_REDIRECT_URI=""

# Resend — from https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Blossom Budget <onboarding@resend.dev>"

# Shared secret so only your cron service can hit /api/cron/* endpoints.
# Generate with: openssl rand -hex 24
CRON_SECRET=""

# Base URL of the deployed app (used in emails and password reset links)
APP_URL="http://localhost:3000"
